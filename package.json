{
  "name": "corpus-coranicum-variants-scrapper",
  "version": "1.0.0",
  "description": "Scraper and dataset for Quranic variant readings from Corpus Coranicum",
  "main": "scrape.js",
  "scripts": {
    "scrape": "node scrape.js",
    "fix": "python3 fix_variants.py",
    "convert": "python3 convert_to_csv.py",
    "test": "uv run pytest test_variants.py -v",
    "validate": "uv run pytest test_variants.py -v",
    "analyze": "python3 find_multiple_variants.py",
    "pipeline": "npm run scrape && npm run fix && npm run convert && npm run test"
  },
  "keywords": [
    "quran",
    "qiraat",
    "variants",
    "corpus-coranicum",
    "islamic-studies",
    "quranic-studies",
    "recitations",
    "dataset"
  ],
  "author": "Abdul Rahim Nizamani <abdulrahimnizamani@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arnizamani/corpus_coranicum_variants_scrapper.git"
  },
  "bugs": {
    "url": "https://github.com/arnizamani/corpus_coranicum_variants_scrapper/issues"
  },
  "homepage": "https://github.com/arnizamani/corpus_coranicum_variants_scrapper#readme",
  "dependencies": {
    "playwright": "^1.59.1"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
